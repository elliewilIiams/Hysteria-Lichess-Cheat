{
  "manifest_version": 3,
  "name": "Hysteria Lichess.org Cheat",
  "version": "1.6.7",
  "description": "Чит-оверлей для анализа позиций на Lichess.org и отрисовки лучших ходов от движка Hysteria. by t.me/hysteria_code",
  "permissions": ["storage"],
  "host_permissions": ["http://127.0.0.1:5267/*"],
  "content_scripts": [
    {
      "matches": ["https://lichess.org/*"],
      "js": ["dist/content.js"],
      "css": ["dist/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
